GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
TOMTOM_TRAFFIC_API_KEY=your_tomtom_traffic_api_key_here
AVIATIONSTACK_API_KEY=your_aviationstack_api_key_here
# SkyLink ADS-B via RapidAPI (optional)
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=skylink-api.p.rapidapi.com
# OpenSky Network OAuth2 — free live aircraft map (preferred)
# Create API client: https://opensky-network.org/my-opensky/account
OPENSKY_CLIENT_ID=your_opensky_client_id
OPENSKY_CLIENT_SECRET=your_opensky_client_secret
# Railway station directory — 8,990+ stations from datameet/railways (CC0)
# Dataset: https://github.com/datameet/railways
# Railway station photos: GET /api/routes/railway/photos?code=SBC&name=...&city=...
# Wikimedia: https://commons.wikimedia.org/wiki/Category:Railway_stations_in_India
IRCTC_CONNECT_API_KEY=irctc_your_key_here
# Optional primary provider: https://indianrailapi.com
INDIAN_RAIL_API_KEY=your_indianrailapi_key_here
# Airport photos use free Wikimedia Commons API (no key needed)
# Backend proxy: GET /api/routes/airport/photos?iata=BLR&name=...&city=...
# Wikimedia API: https://commons.wikimedia.org/w/api.php
# India airports category: https://commons.wikimedia.org/wiki/Category:Airports_in_India
MONGODB_URI=mongodb://localhost:27017/
DATABASE_NAME=smart_route_finder
SECRET_KEY=your_secret_key_here
FLASK_ENV=development
PORT=5000
